# Copy this file to .streamlit/secrets.toml for LOCAL development.
# Streamlit Cloud reads secrets from the Cloud dashboard, NOT from this file.
# NEVER commit .streamlit/secrets.toml to git (it's in .gitignore).

VOYAGE_API_KEY = "your-voyage-key-here"
ANTHROPIC_API_KEY = "your-anthropic-key-here"

# Optional: set a shared passcode to gate access.
# If unset, the app is open to anyone with the URL.
# APP_PASSCODE = "choose-a-passcode"
